{
  "name": "hylee-shopify",
  "version": "1.0.0",
  "private": true,
  "description": "Hy-lee Shopify Hydrogen storefront",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@vitest/coverage-v8": "^4.0.17",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "husky": "^9.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.0",
    "simple-git-hooks": "^2.13.1",
    "vitest": "^1.2.0",
    "workflow-agent-cli": "^2.23.4"
  },
  "scripts": {
    "dev": "cd hydrogen && pnpm dev",
    "build": "cd hydrogen && pnpm build",
    "preview": "cd hydrogen && pnpm preview",
    "typecheck": "cd hydrogen && pnpm typecheck",
    "lint": "cd hydrogen && pnpm lint",
    "lint:fix": "cd hydrogen && pnpm lint --fix",
    "format": "prettier --write \"hydrogen/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"hydrogen/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "workflow": "workflow-agent",
    "context:export": "bash scripts/export-context.sh",
    "synonyms:generate": "tsx scripts/generate-synonyms.ts",
    "synonyms:upload": "tsx scripts/generate-synonyms.ts --upload",
    "visual:header": "cd hydrogen && pnpm visual:header",
    "visual:mobile": "cd hydrogen && pnpm visual:mobile"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@shopify/cli": "^4.1.0",
    "@shopify/hydrogen": "2025.10.1"
  }
}
